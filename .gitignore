# =============================================================================
# dragnet-gpu — .gitignore
# =============================================================================

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
*.env
.env.local
.env.production
.env.staging

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid