# =============================================================================
# dragnet-gpu — Environment Variables
# Copy to .env and fill in values.
# NEVER commit .env to version control.
# =============================================================================

# ── Authentication ─────────────────────────────────────────────────────────
# API key that all Dragnet backends must send in every request.
# Generate with: openssl rand -hex 32
# Malik holds production keys in Azure Key Vault.
INFERENCE_API_KEY=

# ── RunPod ─────────────────────────────────────────────────────────────────
# RunPod API key — from RunPod Settings → API Keys
# Malik holds production keys in Azure Key Vault.
RUNPOD_API_KEY=

# RunPod serverless endpoint ID — from RunPod Serverless dashboard
RUNPOD_ENDPOINT_ID=xjp0viock5cnn6

# ── Models ─────────────────────────────────────────────────────────────────
HEAVY_MODEL=qwen2.5:14b-instruct-q4_K_M
LIGHT_MODEL=qwen2.5:7b-instruct-q4_K_M
EMBED_MODEL=bge-m3

# ── Polling ────────────────────────────────────────────────────────────────
# Seconds to wait for a job to complete before timing out
POLL_TIMEOUT=600
# Seconds between each status check — 1 second gives faster responses
POLL_INTERVAL=1

# ── Application ────────────────────────────────────────────────────────────
PORT=5000
ENV=production