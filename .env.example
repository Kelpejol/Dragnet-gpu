# =============================================================================
# dragnet-gpu — Environment Variables
# Copy to .env and fill in values.
# NEVER commit .env to version control.
# =============================================================================

# ── Authentication ─────────────────────────────────────────────────────────
INFERENCE_API_KEY=

# ── RunPod ─────────────────────────────────────────────────────────────────
RUNPOD_API_KEY=

# Heavy endpoint — 14B model
RUNPOD_HEAVY_ENDPOINT_ID=h6m8xvw9e3f9pk

# Light endpoint — 7B model
RUNPOD_LIGHT_ENDPOINT_ID=xjp0viock5cnn6

# ── Models ─────────────────────────────────────────────────────────────────
HEAVY_MODEL=qwen2.5:14b-instruct-q4_K_M
LIGHT_MODEL=qwen2.5:7b-instruct-q4_K_M
EMBED_MODEL=bge-m3

# ── Polling ────────────────────────────────────────────────────────────────
POLL_TIMEOUT=600
POLL_INTERVAL=2

# ── Qdrant ─────────────────────────────────────────────────────────────────
# Qdrant vector store URL.
# Production: http://127.0.0.1:6333 (localhost only on RunPod pod)
QDRANT_URL=http://127.0.0.1:6333


REDIS_URL=redis://localhost:6379/0


# ── Application ────────────────────────────────────────────────────────────
PORT=8000
ENV=production