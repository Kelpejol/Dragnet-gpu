# # =============================================================================
# # Dragnet GPU Inference Gateway — Environment Variables
# # Copy this file to .env and fill in your values.
# # NEVER commit .env to version control — it contains secrets.
# # In production, these are set as RunPod pod environment variables,
# # not as a .env file.
# #
# # This gateway serves ALL Dragnet AI systems — not just OrgOS.
# # OrgOS (GRC), HR automation, Finance agents, and any future
# # AI-powered product at Dragnet all route through this gateway.
# # =============================================================================

# # ── Authentication ─────────────────────────────────────────────────────────
# # API key that any Dragnet backend must send in every request.
# # Generate with: openssl rand -hex 32
# # Store in Azure Key Vault. Malik (DevOps) holds production keys.
# INFERENCE_API_KEY=

# # ── Ollama ─────────────────────────────────────────────────────────────────
# # Ollama inference server URL.
# # Production: http://127.0.0.1:11434 (localhost only on RunPod pod)
# # Development: http://localhost:11434 (if Ollama is running locally)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# # Model names — must match exactly what `ollama list` shows on the pod
# HEAVY_MODEL=qwen2.5:14b-instruct-q4_K_M
# LIGHT_MODEL=qwen2.5:7b-instruct-q4_K_M
# EMBED_MODEL=bge-m3

# # Ollama request timeout in seconds.
# # The 14B model can take 30-90 seconds for long documents.
# OLLAMA_TIMEOUT=300

# # ── Redis ──────────────────────────────────────────────────────────────────
# # Redis connection URL including password.
# # Production: redis://:REDIS_PASSWORD@127.0.0.1:6379/0
# # Development: redis://localhost:6379/0 (no password needed locally)
# REDIS_URL=redis://localhost:6379/0

# # ── Qdrant ─────────────────────────────────────────────────────────────────
# # Qdrant vector store URL.
# # Production: http://127.0.0.1:6333 (localhost only on RunPod pod)
# QDRANT_URL=http://127.0.0.1:6333

# # ── Application ────────────────────────────────────────────────────────────
# PORT=8000

# # Set to "production" on RunPod.
# # Controls: /docs visibility, CORS origins, log level.
# ENV=development

# # ── HuggingFace ────────────────────────────────────────────────────────────
# # READ-only token for the Dragnet HuggingFace organisation account.
# # Used only during initial model download on the RunPod pod.
# # Not needed for day-to-day inference operations.
# # Store in Azure Key Vault — ask Malik for access.
# HF_TOKEN=







# =============================================================================
# dragnet-gpu — Environment Variables
# Copy to .env and fill in values.
# NEVER commit .env to version control.
# =============================================================================

# ── Authentication ─────────────────────────────────────────────────────────
# API key that OrgOS/eRecruiter must send in every request.
# Generate with: openssl rand -hex 32
# Malik holds production keys in Azure Key Vault.
INFERENCE_API_KEY=

# ── RunPod ─────────────────────────────────────────────────────────────────
# RunPod API key — from RunPod Settings → API Keys
# Malik holds production keys in Azure Key Vault.
RUNPOD_API_KEY=

# RunPod serverless endpoint ID
RUNPOD_ENDPOINT_ID=

# ── Models ─────────────────────────────────────────────────────────────────
HEAVY_MODEL=qwen2.5:14b-instruct-q4_K_M
LIGHT_MODEL=qwen2.5:7b-instruct-q4_K_M
EMBED_MODEL=bge-m3

# ── Polling ────────────────────────────────────────────────────────────────
POLL_TIMEOUT=300
POLL_INTERVAL=2

# ── Application ────────────────────────────────────────────────────────────
PORT=8000
ENV=development